})

  


function nextSlide() {
  index++;
  if (index >= totalSlides) {
    index = 0;
  }
  slides.style.transform = `translateX(-${index * 100}%)`;
}

function prevSlide() {
  index--;
  if (index < 0) {
    index = totalSlides - 1;
  }
  slides.style.transform = `translateX(-${index * 100}%)`;
}